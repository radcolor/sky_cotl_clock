{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "isekai",
  "version": "0.1.0",
  "identifier": "dev.radcolor.sky-cotl-clock",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Isekai",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 640
      },
      {
        "label": "overlay",
        "title": "Isekai Clock Overlay",
        "width": 360,
        "height": 420,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5OEVBRkUyNTJCMjI4QzAKUldUQUtMSlM0cStPV2RoOUhJQU85Nk9hSy80N3RCRjJBeFJrUyttVUN3dEZLbkQrZndmVWtic2wK",
      "endpoints": [
        "https://github.com/radcolor/sky_cotl_clock/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
